FoamFile
{
    version         2;
    format          ascii;
    class           dictionary;
    location        "system";
    object          controlDict;
}

application     foamRun;

solver          fluid;

/* startFrom       startTime; */
startFrom       latestTime;

startTime       0.0;

stopAt          endTime;

endTime         5e-3;

deltaT          1e-5;

writeControl    adjustableRunTime;

writeInterval   5e-4;

purgeWrite 	    0;

writeFormat     ascii;//binary;

writePrecision  10;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable yes;

adjustTimeStep  yes;

maxCo           0.5;

libs
(
"libsyntheticTurbulenceInlet.so"
);

functions
{
  #includeFunc    patchSurface
}


