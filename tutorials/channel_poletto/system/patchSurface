Description
    Writes the inlet patch U field to VTK each write time so the effect of
    the syntheticTurbulenceInlet boundary condition can be visualised.

\*---------------------------------------------------------------------------*/

type                surfaces;
libs                ("libsampling.so");

interpolationScheme cellPoint;
surfaceFormat       vtk;

fields              (U);

writeControl        writeTime;
writeFields         false;

surfaces
(
    inlet
    {
        type        patch;
        patches     (inlet);
    }
);

