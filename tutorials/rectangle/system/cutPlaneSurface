//#includeEtc "caseDicts/functions/surface/cutPlaneSurface.cfg"

// ************************************************************************* //

  type            surfaces;
  libs            ("libsampling.so");
  writeControl    adjustableRunTime;
  writeInterval   1e-4;
  surfaceFormat   vtk;
  fields ( U p T rho k nut H2 H O2 O OH H2O HO2 H2O2 N2 LMA Qdot vorticity);
  interpolationScheme     cellPoint;
  surfaces
  (
          yNormal
          {
                  type        cutPlane;
                  planeType   pointAndNormal;
                  point   (0.1 0 0);
                  normal  (0 1 0);
                  interpolate true;
          }
