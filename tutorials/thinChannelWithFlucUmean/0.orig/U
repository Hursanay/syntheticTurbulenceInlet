FoamFile
{
  version     2.0;
  format      ascii;
  class       volVectorField;
  location    "1";
  object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 1 -1 0 0 0 0 ];

internalField   uniform ( 5.0521 0 0 );

boundaryField
{
  inlet
  {
    type            syntheticTurbulenceInlet;
    value           $internalField;
    geometryMode    channel; //available: annulus, disk, rectangle or channel
    wallLongOrShort long; //wall on the long or the short side
    Umean           table #include "RandomForcing_InletU.dat" //mean speed in the main flow direction
    /* Umean           17.55; //mean speed in the main flow direction */

    //Utau            -10; // friction velocity; Default: Utau is calculated from the expression for a smooth pipe (the lower limit can be forced by e.g. a negative value)
    //swirlNr         0.0; //swirl number; Default: 0.

    delta           2; //Characteristic length scale; Default: 1 but should specify.
    //d               1; //Ratio of sum of eddy volumes to eddy box volume, i.e. eddy density; Default: 1.
    //nCellPerEddy    1; //Minimum eddy length in units of number of cells; Default: 5.
    //scale           1; //Heuristic scaling factor (scales U'); Default: 1.
    }

  bottomWall
  {
    type            fixedValue;
    value           uniform ( 0 0 0 );
  }
  topWall
  {
    type            fixedValue;
    value           uniform ( 0 0 0 );
  }
  sides_half0
  {
    type            cyclic;
  }
  sides_half1
  {
    type            cyclic;
  }

  outlet
  {
    type            inletOutlet;
    inletValue      uniform (0 0 0);
    value           uniform (0 0 0);
  }

}


